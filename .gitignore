node_modules/
.next/
out/
*.tsbuildinfo
.env*.local
npm-debug.log*

# The function's dist/ is regenerated by netlify.toml's build command
# (prisma generate + tsc) on every deploy — not committed. shared/dist/ is
# deliberately NOT listed here: nothing in the build pipeline builds the
# vendored @hrm/shared package, so it ships pre-built and committed instead.
# Likewise prisma/seed-template.db (pre-migrated + pre-seeded demo DB
# template) is intentionally committed — see README.
netlify/functions/api/dist/

# Any local throwaway SQLite file created while testing this function
# locally — the one intentional exception is seed-template.db, above.
netlify/functions/api/prisma/*.db
netlify/functions/api/prisma/*.db-journal
!netlify/functions/api/prisma/seed-template.db
